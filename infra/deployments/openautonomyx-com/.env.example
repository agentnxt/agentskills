# Liferay — Environment for www.openautonomyx.com
# Copy to .env and fill in all required values.

# ── Liferay ─────────────────────────────────────────────────────
LIFERAY_DB_NAME=lportal
LIFERAY_DB_USER=liferay
LIFERAY_DB_PASSWORD=            # REQUIRED — generate: openssl rand -hex 32
LIFERAY_ADMIN_EMAIL=admin@openautonomyx.com

# ── Misc ─────────────────────────────────────────────────────────
TZ=UTC
